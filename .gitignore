.env
venv/
# dont track images
frame*.jpg
# Block any folder starting with 202
202*/
# Block any specific image inside any 202 folder
202*/*.jpg
.vscode/
__pycache__/
# Learnings:

# venv startup: i.  Set-ExecutionPolicy -Scope Process -ExecutionPolicy Remote
#               ii. ./venv/scripts/Activate

# Pipreqs library: To add only those libraries actually imported in the files
#                  Command: pipreqs . --force

# Final to enforce constant or static rule
#   Eg: from typing import Final
#       CONNECTION_STRING: Final = "<>"
